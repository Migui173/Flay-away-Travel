{
  "info": {
    "name": "Fly Away Travel API",
    "description": "Colección completa para el Lab 07 - CS 2031 DBP",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🧹 Cleanup",
      "item": [
        {
          "name": "DELETE /cleanup",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/cleanup",
              "host": ["{{base_url}}"],
              "path": ["cleanup"]
            },
            "description": "Limpia completamente la base de datos. Requerido para que los tests funcionen."
          },
          "response": []
        }
      ]
    },
    {
      "name": "✈️ Flights",
      "item": [
        {
          "name": "POST /flights/create",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"airlineName\": \"American Airlines\",\n  \"flightNumber\": \"AA984\",\n  \"estDepartureTime\": \"2026-06-01T08:00:00\",\n  \"estArrivalTime\": \"2026-06-01T12:00:00\",\n  \"availableSeats\": 150\n}"
            },
            "url": {
              "raw": "{{base_url}}/flights/create",
              "host": ["{{base_url}}"],
              "path": ["flights", "create"]
            },
            "description": "Crea un vuelo. Sin protección JWT.\n\nValidaciones:\n- flightNumber: A-Z y 0-9, máximo 6 caracteres\n- estDepartureTime < estArrivalTime\n- availableSeats > 0\n- flightNumber único"
          },
          "response": []
        },
        {
          "name": "POST /flights/create - Número inválido",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"airlineName\": \"American Airlines\",\n  \"flightNumber\": \"aa984\",\n  \"estDepartureTime\": \"2026-06-01T08:00:00\",\n  \"estArrivalTime\": \"2026-06-01T12:00:00\",\n  \"availableSeats\": 150\n}"
            },
            "url": {
              "raw": "{{base_url}}/flights/create",
              "host": ["{{base_url}}"],
              "path": ["flights", "create"]
            },
            "description": "Debe retornar 400 - número de vuelo en minúsculas"
          },
          "response": []
        },
        {
          "name": "POST /flights/create - Fechas inválidas",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"airlineName\": \"American Airlines\",\n  \"flightNumber\": \"AA001\",\n  \"estDepartureTime\": \"2026-06-01T12:00:00\",\n  \"estArrivalTime\": \"2026-06-01T08:00:00\",\n  \"availableSeats\": 150\n}"
            },
            "url": {
              "raw": "{{base_url}}/flights/create",
              "host": ["{{base_url}}"],
              "path": ["flights", "create"]
            },
            "description": "Debe retornar 400 - hora de salida mayor a hora de llegada"
          },
          "response": []
        },
        {
          "name": "GET /flights/{id}",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/flights/1",
              "host": ["{{base_url}}"],
              "path": ["flights", "1"]
            },
            "description": "Obtiene un vuelo por ID. Requiere JWT."
          },
          "response": []
        },
        {
          "name": "GET /flights/search - Por número de vuelo",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/flights/search?flightNumber=AA",
              "host": ["{{base_url}}"],
              "path": ["flights", "search"],
              "query": [
                {
                  "key": "flightNumber",
                  "value": "AA"
                }
              ]
            },
            "description": "Búsqueda parcial por número de vuelo. Requiere JWT."
          },
          "response": []
        },
        {
          "name": "GET /flights/search - Por aerolínea",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/flights/search?airlineName=American",
              "host": ["{{base_url}}"],
              "path": ["flights", "search"],
              "query": [
                {
                  "key": "airlineName",
                  "value": "American"
                }
              ]
            },
            "description": "Búsqueda parcial por nombre de aerolínea. Requiere JWT."
          },
          "response": []
        },
        {
          "name": "GET /flights/search - Por rango de fechas (Nice to Have)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/flights/search?start=2026-06-01T00:00:00&end=2026-06-30T23:59:59",
              "host": ["{{base_url}}"],
              "path": ["flights", "search"],
              "query": [
                {
                  "key": "start",
                  "value": "2026-06-01T00:00:00"
                },
                {
                  "key": "end",
                  "value": "2026-06-30T23:59:59"
                }
              ]
            },
            "description": "Búsqueda por rango de fechas de salida. Requiere JWT."
          },
          "response": []
        }
      ]
    },
    {
      "name": "👤 Users",
      "item": [
        {
          "name": "POST /users/register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Guarda el userId automáticamente si la respuesta tiene id",
                  "const res = pm.response.json();",
                  "if (res.id) {",
                  "    pm.collectionVariables.set('user_id', res.id);",
                  "    console.log('User ID guardado:', res.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"miguel@example.com\",\n  \"firstName\": \"Miguel\",\n  \"lastName\": \"Garcia\",\n  \"password\": \"Password1\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/register",
              "host": ["{{base_url}}"],
              "path": ["users", "register"]
            },
            "description": "Registra un usuario. Sin protección JWT.\n\nValidaciones:\n- email válido\n- firstName y lastName: mínimo 1 mayúscula\n- password: mínimo 8 chars, al menos 1 letra y 1 número\n\nRetorna solo el id (Nice to Have)"
          },
          "response": []
        },
        {
          "name": "POST /users/register - Email inválido",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"no-es-un-email\",\n  \"firstName\": \"Miguel\",\n  \"lastName\": \"Garcia\",\n  \"password\": \"Password1\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/register",
              "host": ["{{base_url}}"],
              "path": ["users", "register"]
            },
            "description": "Debe retornar 400 - email inválido"
          },
          "response": []
        },
        {
          "name": "POST /users/register - Sin mayúscula en nombre",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"firstName\": \"miguel\",\n  \"lastName\": \"garcia\",\n  \"password\": \"Password1\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/register",
              "host": ["{{base_url}}"],
              "path": ["users", "register"]
            },
            "description": "Debe retornar 400 - firstName y lastName deben iniciar con mayúscula"
          },
          "response": []
        },
        {
          "name": "POST /users/register - Contraseña débil",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"firstName\": \"Miguel\",\n  \"lastName\": \"Garcia\",\n  \"password\": \"abc\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/register",
              "host": ["{{base_url}}"],
              "path": ["users", "register"]
            },
            "description": "Debe retornar 400 - contraseña muy corta y sin número"
          },
          "response": []
        }
      ]
    },
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "POST /auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Guarda el token automáticamente después del login",
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "    pm.collectionVariables.set('token', res.token);",
                  "    console.log('Token guardado:', res.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"miguel@example.com\",\n  \"password\": \"Password1\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Login con email y contraseña. Retorna JWT token.\n\nEl token se guarda automáticamente en la variable {{token}} de la colección."
          },
          "response": []
        },
        {
          "name": "POST /auth/login - Email desconocido",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"noexiste@example.com\",\n  \"password\": \"Password1\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Debe retornar 401 - email no registrado"
          },
          "response": []
        },
        {
          "name": "POST /auth/login - Contraseña incorrecta",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"miguel@example.com\",\n  \"password\": \"WrongPass1\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Debe retornar 401 - contraseña incorrecta"
          },
          "response": []
        }
      ]
    },
    {
      "name": "📋 Bookings",
      "item": [
        {
          "name": "POST /flights/book",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Guarda el booking id automáticamente",
                  "const res = pm.response.json();",
                  "if (res.id) {",
                  "    pm.collectionVariables.set('booking_id', res.id);",
                  "    console.log('Booking ID guardado:', res.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"flightId\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/flights/book",
              "host": ["{{base_url}}"],
              "path": ["flights", "book"]
            },
            "description": "Reserva un vuelo. Requiere JWT.\n\nEl usuario se obtiene automáticamente del token.\nNo permite sobrevender, vuelos pasados ni conflictos de horario."
          },
          "response": []
        },
        {
          "name": "POST /flights/book - Sin asientos",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"flightId\": 99\n}"
            },
            "url": {
              "raw": "{{base_url}}/flights/book",
              "host": ["{{base_url}}"],
              "path": ["flights", "book"]
            },
            "description": "Debe retornar 400 - vuelo no encontrado o sin asientos"
          },
          "response": []
        },
        {
          "name": "GET /flight/book/{id}",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/flight/book/{{booking_id}}",
              "host": ["{{base_url}}"],
              "path": ["flight", "book", "{{booking_id}}"]
            },
            "description": "Obtiene una reserva por ID. Requiere JWT.\n\nNota: es /flight (singular) según el enunciado."
          },
          "response": []
        }
      ]
    }
  ]
}